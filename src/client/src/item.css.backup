.item-container {
    display: flex;
    
    padding: 10px;
    gap: 5px;
    overflow: auto;
}

.item-container:hover {
    background-color: gray;
    cursor:pointer;
}

.item-container-selected {
    display: flex;
    background-color:brown;
    padding: 10px;
    gap: 5px;
    overflow: auto;
    cursor:pointer;
}

.item-container-searched {
    display: flex;
    background-color:deepskyblue;
    padding: 10px;
    gap: 5px;
    overflow: auto;
    cursor:pointer;
}

.item-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr 1fr 1fr;
    gap: 5px;
    color:white;
    font-size: 11pt;
}

.itemImg {
    width:120px;
    height:140px;
}

.item-name {
    grid-column: 1 / 3;
    grid-row: 1;
}
.item-type {
    grid-column: 1;
    grid-row: 2;
}
.item-id {
    grid-column: 2;
    grid-row: 2;
}
.item-lat {
    grid-column: 1;
    grid-row: 3;
    display: flex;
}
.item-lat-label {
    
}
.item-lat-value {
    padding: 2px;
    text-align: center;
    align-items: center;
    display: flex;
    border:2px solid rgb(197, 194, 194);
}
.item-lon {
    grid-column: 2;
    grid-row: 3;
}
.item-timestamp {
    grid-column: 1 / 3;
    grid-row: 4;
}